<DAGGODesignSystem version="2.0" name="Operational Precision" supersedes="Memoria Design System">

  <Context>
    <Product>DAGGO</Product>
    <Intent>
      Replace the existing Memoria-style premium analytics aesthetic with a tighter, more operational, Dagster-like orchestration UI.
    </Intent>
    <PrimaryGoals>
      <Goal>Dark mode first</Goal>
      <Goal>Tighter UI density (20-30% denser than Memoria)</Goal>
      <Goal>Stronger background/surface layering for hierarchy</Goal>
      <Goal>Pragmatic, engineered feel: reliable, deterministic, observability-first</Goal>
      <Goal>Allow limited accent colors for system states (runs/nodes/logs)</Goal>
    </PrimaryGoals>
    <AntiGoals>
      <AntiGoal>Luxury journal vibe</AntiGoal>
      <AntiGoal>Theatrical animations (blur-to-clear, sequential reveals)</AntiGoal>
      <AntiGoal>3D glare, border beams, ambient starfields</AntiGoal>
      <AntiGoal>Excessive whitespace or oversized hero typography</AntiGoal>
      <AntiGoal>Accent colors as decoration</AntiGoal>
    </AntiGoals>
    <Influences>
      <Influence>Dagster UI (dark, layered, dense, operational)</Influence>
      <Influence>Linear (tight spacing, crisp hierarchy)</Influence>
      <Influence>Modern infra consoles (logs/events/inspector panels)</Influence>
    </Influences>
  </Context>

  <Principles>
    <Principle id="P1" name="Structure Over Atmosphere">
      <Description>Surfaces and layout communicate hierarchy and meaning, not ambiance effects.</Description>
      <Implications>
        <Implication>Prefer panel framing, borders, and layered backgrounds.</Implication>
        <Implication>Avoid mood components and cinematic transitions.</Implication>
      </Implications>
    </Principle>

    <Principle id="P2" name="Background Layering Defines Hierarchy">
      <Description>Hierarchy comes primarily from discrete surface levels and border clarity.</Description>
      <Implications>
        <Implication>App -> Panel -> Card -> Elevated -> Hover/Active surfaces are visibly distinct.</Implication>
      </Implications>
    </Principle>

    <Principle id="P3" name="Density With Legibility">
      <Description>Increase information density ~20-30% vs Memoria while remaining readable.</Description>
      <Implications>
        <Implication>Reduce padding, gaps, row heights; keep type sizes stable.</Implication>
        <Implication>Use section headers and separators to preserve clarity.</Implication>
      </Implications>
    </Principle>

    <Principle id="P4" name="System Accents For State Only">
      <Description>Muted accent colors are allowed but only for runtime and severity states.</Description>
      <AllowedUses>
        <Use>Run status (success/failure/running/queued)</Use>
        <Use>Node status (ready/running/failing/skipped)</Use>
        <Use>Log severity (info/warn/error/debug)</Use>
        <Use>Timeline indicators and chips</Use>
      </AllowedUses>
      <DisallowedUses>
        <Use>Decoration</Use>
        <Use>Category color-coding without strong need</Use>
        <Use>Accents for emphasis when typography/layout can do it</Use>
      </DisallowedUses>
    </Principle>

    <Principle id="P5" name="Minimal Motion, Fast Feedback">
      <Description>Motion supports comprehension (hover, expand/collapse, tab indicator) and stays fast.</Description>
      <Constraints>
        <Constraint>150-250ms hover transitions</Constraint>
        <Constraint>Accordion expand/collapse only</Constraint>
        <Constraint>No page-load cinematic sequences</Constraint>
        <Constraint>No blur-to-clear text or word-by-word reveals</Constraint>
      </Constraints>
    </Principle>
  </Principles>

  <Tokens>
    <Color>
      <Surfaces>
        <Token name="bg.app" value="#0B0F14" usage="Main app background"/>
        <Token name="bg.panel" value="#11161C" usage="Sidebar, split panels, containers"/>
        <Token name="bg.card" value="#151B23" usage="Cards, inner containers"/>
        <Token name="bg.elevated" value="#1B2230" usage="Popovers, modals, focused regions"/>
        <Token name="bg.hover" value="#202938" usage="Hover states"/>
        <Token name="bg.active" value="#263244" usage="Selected/active states"/>
      </Surfaces>

      <Borders>
        <Token name="border.subtle" value="#1F2633" usage="Panel dividers, light separators"/>
        <Token name="border.default" value="#273142" usage="Card borders, common separators"/>
        <Token name="border.strong" value="#344055" usage="Active focus boundary, graph emphasis"/>
      </Borders>

      <Text>
        <Token name="text.primary" value="#E6EDF3" usage="Primary labels, headings"/>
        <Token name="text.secondary" value="#9BA7B4" usage="Supporting text"/>
        <Token name="text.muted" value="#6B7785" usage="Metadata, timestamps"/>
        <Token name="text.dim" value="#4B5563" usage="Disabled, placeholder, very muted"/>
      </Text>

      <Accents purpose="StateOnly">
        <Token name="state.success" value="#2FBF71" usage="Success states"/>
        <Token name="state.error" value="#E5484D" usage="Failure/destructive states"/>
        <Token name="state.running" value="#3B82F6" usage="In-progress/running states"/>
        <Token name="state.queued" value="#F59E0B" usage="Queued/warn states"/>
      </Accents>
    </Color>

    <Typography>
      <FontFamilies>
        <Font name="ui" value="system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial"/>
        <Font name="mono" value="ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono"/>
      </FontFamilies>

      <Weights>
        <Weight name="normal" value="400" usage="Default body"/>
        <Weight name="medium" value="500" usage="Section headers, labels, nav"/>
        <Weight name="semibold" value="600" usage="Active tabs, node titles, key emphasis"/>
      </Weights>

      <Sizes>
        <Size name="pageTitle" value="text-xl" usage="Primary page title"/>
        <Size name="sectionHeader" value="text-sm" usage="Panel header titles"/>
        <Size name="body" value="text-sm" usage="Default body text"/>
        <Size name="meta" value="text-xs" usage="Metadata, timestamps"/>
        <Size name="graphLabel" value="text-xs" usage="Graph labels"/>
        <Size name="log" value="text-xs" usage="Logs (mono)"/>
      </Sizes>

      <Tracking>
        <Tracking name="label" value="tracking-wide" usage="Uppercase section labels"/>
        <Tracking name="tight" value="tracking-tight" usage="Numbers, compact labels"/>
      </Tracking>

      <Case>
        <Rule>Panel section labels may be uppercase with tracking-wide.</Rule>
        <Rule>Primary titles are sentence-case.</Rule>
      </Case>
    </Typography>

    <Spacing>
      <Targets>
        <Target id="density.increase" value="20-30%" comparedTo="Memoria"/>
      </Targets>
      <Scale>
        <Token name="page.padding" value="p-4" replaces="p-6"/>
        <Token name="panel.gap" value="gap-4" replaces="gap-6"/>
        <Token name="card.padding" value="p-3" replaces="p-4"/>
        <Token name="row.padding" value="py-2.5 px-3" replaces="p-4"/>
      </Scale>
    </Spacing>

    <Radii>
      <Token name="radius.sm" value="rounded-md" usage="Small controls"/>
      <Token name="radius.md" value="rounded-lg" usage="Buttons, compact cards"/>
      <Token name="radius.lg" value="rounded-xl" usage="Panels, modals"/>
    </Radii>

    <Shadows>
      <Rule>Shadows are minimal and used only for elevated overlays.</Rule>
      <Token name="shadow.elevated" value="shadow-lg" usage="Modals/popovers"/>
    </Shadows>

    <Motion>
      <Durations>
        <Token name="hover" value="150-250ms"/>
        <Token name="accordion" value="200-300ms"/>
        <Token name="tabIndicator" value="250-400ms"/>
      </Durations>
      <Allowed>
        <MotionType>Hover transitions (bg/border/text)</MotionType>
        <MotionType>Accordion expand/collapse</MotionType>
        <MotionType>Tab indicator slide</MotionType>
        <MotionType>Timeline bar growth (subtle)</MotionType>
      </Allowed>
      <Disallowed>
        <MotionType>Blur-to-clear page transitions</MotionType>
        <MotionType>Word-by-word text reveals</MotionType>
        <MotionType>3D glare / perspective tilts</MotionType>
        <MotionType>BorderBeam theatrical effects</MotionType>
        <MotionType>Ambient starfields / onboarding theatrics</MotionType>
      </Disallowed>
    </Motion>
  </Tokens>

  <Layout>
    <AppShell>
      <Regions>
        <Region name="Sidebar" description="Primary navigation; collapsible; icons always visible"/>
        <Region name="Topbar" description="Contextual controls, breadcrumbs, environment, global actions"/>
        <Region name="Main" description="Split panels: graph + inspector, or runs + logs, etc."/>
      </Regions>
      <Dividers>
        <Divider usage="SidebarRight" class="border-r border-subtle"/>
        <Divider usage="TopbarBottom" class="border-b border-subtle"/>
        <Divider usage="PanelSplit" class="border-l border-subtle"/>
      </Dividers>
    </AppShell>

    <PanelPattern name="PanelHeaderBodyFooter">
      <Header>
        <Style bg="bg.panel" borderBottom="border-subtle"/>
        <Structure>
          <Left>Title / context</Left>
          <Right>Controls / filters / actions</Right>
        </Structure>
      </Header>
      <Body>
        <Style bg="bg.panel"/>
      </Body>
      <Footer optional="true">
        <Style bg="bg.panel" borderTop="border-subtle"/>
      </Footer>
    </PanelPattern>

    <DensityGuidelines>
      <Guideline>Prefer split panels over large single canvases.</Guideline>
      <Guideline>Use visible separators to maintain readability at higher density.</Guideline>
      <Guideline>Keep lists tight but provide hover row highlight.</Guideline>
    </DensityGuidelines>
  </Layout>

  <Components>
    <Component name="Card">
      <Base class="bg-card border border-default rounded-lg p-3"/>
      <Hover class="hover:bg-hover hover:border-strong transition-colors"/>
      <Selected class="bg-active border-strong"/>
      <Notes>
        <Note>No BorderBeam, no 3D glare, no ambient effects.</Note>
      </Notes>
    </Component>

    <Component name="Button">
      <Primary class="bg-active border border-strong text-primary rounded-md px-3 py-2 hover:bg-hover"/>
      <Secondary class="bg-card border border-default text-secondary rounded-md px-3 py-2 hover:bg-hover hover:text-primary"/>
      <IconButton class="h-8 w-8 bg-card border border-default rounded-md text-muted hover:text-primary hover:bg-hover"/>
    </Component>

    <Component name="Input">
      <Text class="bg-card border border-default rounded-md px-3 py-2 text-primary placeholder:text-dim focus:border-strong"/>
      <Search variant="withIcon" notes="Icon left, text-xs/meta labels in panel headers"/>
    </Component>

    <Component name="Tabs">
      <Container class="flex gap-1 bg-panel border border-subtle rounded-md p-1"/>
      <Tab class="px-3 py-1.5 text-sm text-muted hover:text-secondary"/>
      <ActiveTab class="text-primary" indicator="bg-active rounded-md"/>
      <Motion>Use shared layout indicator (subtle).</Motion>
    </Component>

    <Component name="ListRow">
      <Base class="py-2.5 px-3 border-b border-subtle text-secondary"/>
      <Hover class="hover:bg-hover hover:text-primary"/>
      <Selected class="bg-active text-primary"/>
      <Meta class="text-xs text-muted"/>
    </Component>

    <Component name="StatusChip">
      <Base class="px-2 py-0.5 text-xs rounded-md border"/>
      <States>
        <State name="success" border="state.success/40" text="state.success"/>
        <State name="error" border="state.error/40" text="state.error"/>
        <State name="running" border="state.running/40" text="state.running"/>
        <State name="queued" border="state.queued/40" text="state.queued"/>
      </States>
      <Rule>Chips indicate system state only; no decorative usage.</Rule>
    </Component>

    <Component name="Modal">
      <Backdrop class="fixed inset-0 bg-black/60"/>
      <Container class="bg-elevated border border-default rounded-xl p-4 shadow-elevated"/>
      <Header class="flex items-center justify-between border-b border-subtle pb-2 mb-3"/>
      <Motion>Fast fade/scale only; no 3D rotate.</Motion>
    </Component>

    <Component name="LogsPanel">
      <Container class="bg-black/40 border border-subtle rounded-lg"/>
      <Row class="font-mono text-xs py-1.5 px-2 border-b border-subtle last:border-b-0"/>
      <Severity>
        <Info text="text-secondary"/>
        <Warn text="state.queued"/>
        <Error text="state.error"/>
        <Debug text="text-muted"/>
      </Severity>
      <Rule>Logs prioritize density, alignment, and scanning.</Rule>
    </Component>
  </Components>

  <GraphView>
    <Intent>Graph is primary; must feel precise, mechanical, and legible.</Intent>

    <Node>
      <Base bg="bg-card" border="border.default" radius="radius.md" padding="p-3"/>
      <Hover bg="bg.elevated" border="border.strong"/>
      <Active bg="bg.active" border="border.strong"/>
      <StateIndicators>
        <Indicator type="dot" position="left" usage="status"/>
        <Indicator type="leftBorder" usage="running/failure emphasis (subtle)"/>
      </StateIndicators>
      <DisallowedEffects>
        <Effect>3D glare</Effect>
        <Effect>BorderBeam</Effect>
        <Effect>Blur theatrics</Effect>
      </DisallowedEffects>
    </Node>

    <Edge>
      <Base color="#344055" width="1"/>
      <Hover color="#4A5A74" width="1"/>
      <Active color="#60789A" width="1.5"/>
      <Rule>Edges brighten slightly on hover/selection; never neon.</Rule>
    </Edge>

    <Canvas>
      <Background>bg.panel</Background>
      <Grid optional="true" style="very subtle" rule="If used, keep near-invisible"/>
    </Canvas>
  </GraphView>

  <RunsAndTimeline>
    <RunList>
      <RowPattern component="ListRow"/>
      <StatusPlacement>Left of run name or as trailing chip</StatusPlacement>
      <Density>Compact; optimized for scanning</Density>
    </RunList>

    <Timeline>
      <Row class="py-2 px-3 border-b border-subtle hover:bg-hover"/>
      <Markers>
        <Marker type="stateDot" uses="state.* tokens"/>
        <Marker type="durationBar" style="subtle growth animation allowed"/>
      </Markers>
      <Rule>No flashy animation; clarity over flourish.</Rule>
    </Timeline>

    <EventStream>
      <Row class="py-2 px-3 border-b border-subtle"/>
      <SeverityUses>Use log severity color tokens only</SeverityUses>
      <Rule>Event stream behaves like an ops console: dense, aligned, scannable.</Rule>
    </EventStream>
  </RunsAndTimeline>

  <Sidebar>
    <Container class="bg.panel border-r border-subtle"/>
    <Item>
      <Base class="px-3 py-2 text-sm text-muted rounded-md"/>
      <Hover class="hover:bg-hover hover:text-primary"/>
      <Active class="bg-active text-primary"/>
      <Rule>Icons always visible; labels may collapse.</Rule>
    </Item>
  </Sidebar>

  <DoNotShip>
    <RemoveOrDeprecate>
      <Item>BorderBeam</Item>
      <Item>ProgressiveBlur (unless required for a specific overflow issue)</Item>
      <Item>3D Card Glare</Item>
      <Item>StarsBackground / ShootingStars</Item>
      <Item>TextGenerateEffect</Item>
      <Item>LampContainer / OrbitingCircles onboarding theatrics</Item>
      <Item>Blur-to-clear page transitions</Item>
    </RemoveOrDeprecate>
  </DoNotShip>

  <AcceptanceCriteria>
    <Criteria id="AC1">
      <Statement>Visual hierarchy is defined by surface layering and borders, not emptiness or animation.</Statement>
    </Criteria>
    <Criteria id="AC2">
      <Statement>Information density increases by ~20-30% vs Memoria without reducing readability.</Statement>
    </Criteria>
    <Criteria id="AC3">
      <Statement>Accent colors exist only for runtime/severity state; no decorative accents appear elsewhere.</Statement>
    </Criteria>
    <Criteria id="AC4">
      <Statement>Animations are minimal and fast (hover, tabs, accordions) with no cinematic page sequences.</Statement>
    </Criteria>
    <Criteria id="AC5">
      <Statement>The Graph view feels precise and engineered: clean nodes/edges, clear selection, legible labels.</Statement>
    </Criteria>
    <Criteria id="AC6">
      <Statement>Runs, timeline, and logs behave like an ops console: compact rows, strong scanning affordances.</Statement>
    </Criteria>
    <Criteria id="AC7">
      <Statement>No removed Memoria-only visual effects remain in DAGGO core screens.</Statement>
    </Criteria>
  </AcceptanceCriteria>

</DAGGODesignSystem>
