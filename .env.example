# DAGGO environment template
# Copy to `.env` for local development of the sample binary in `cmd/api`.

# Admin UI + RPC
DAGGO_ADMIN_PORT=8000
# DAGGO_ADMIN_SECRET_KEY=replace-me
DAGGO_ALLOWED_ORIGINS=*
# DAGGO_DISABLE_UI=false

# Database
# SQLite is the default and is fully implemented.
DAGGO_DATABASE_DRIVER=sqlite
DAGGO_SQLITE_PATH=/tmp/daggo.sqlite
# DAGGO_SQLITE_DSN=file:/tmp/daggo.sqlite?cache=shared&mode=rwc

# PostgreSQL is optional and only activates when DAGGO_DATABASE_DRIVER=postgres.
# DAGGO_DATABASE_DRIVER=postgres
# DAGGO_POSTGRES_HOST=localhost
# DAGGO_POSTGRES_PORT=5432
# DAGGO_POSTGRES_USER=daggo
# DAGGO_POSTGRES_PASSWORD=secret
# DAGGO_POSTGRES_DATABASE=platform
# DAGGO_POSTGRES_SCHEMA=my_project
# DAGGO_POSTGRES_SSLMODE=require

# Execution
RUN_QUEUE_SIZE=128
RUN_EXECUTION_MODE=subprocess
RUN_MAX_CONCURRENT_RUNS=1
RUN_MAX_CONCURRENT_STEPS=8

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_KEY=monolith
SCHEDULER_TICK_SECONDS=15
SCHEDULER_MAX_DUE_PER_TICK=24

# Deploy drain lock
DEPLOY_LOCK_PATH=runtime/WILL_DEPLOY
DEPLOY_LOCK_POLL_SECONDS=1
DEPLOY_DRAIN_GRACE_SECONDS=900

# Optional: S3-compatible storage
S3_URL=http://localhost:9000
S3_BUCKET_NAME=daggo-artifacts
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=dummy
S3_SECRET_ACCESS_KEY=dummy
S3_ENTITIES_BUCKET_REQUIRED=false
# S3_ENTITIES_BUCKET_NAME=
# S3_SERVER_SIDE_ENCRYPTION=
# S3_SSE_KMS_KEY_ID=

# Optional: remote Playwright
PLAYWRIGHT_WS_URL=ws://localhost:3000/
PLAYWRIGHT_WS_PROTOCOL=playwright
PLAYWRIGHT_CDP_URL=http://localhost:9222
PLAYWRIGHT_REQUIRE_EXISTING_CONTEXT=false

# Optional: Ollama
OLLAMA_URL=http://localhost:11434
# OLLAMA_API_KEY=
# OLLAMA_AUTH_HEADER=
